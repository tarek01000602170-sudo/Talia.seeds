// قواعد أمان Firestore - انسخ ده في Firebase Console > Firestore > Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // المنتجات: أي حد يقدر يقرا (للمتجر العام)، التعديل للمسجلين فقط
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // المنتجات (صور وتفاصيل) - عامة للقراءة
    match /shippingCompanies/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // الطلبات من المتجر: أي حد يقدر يضيف طلب جديد، الإدارة فقط تشوف
    match /sales/{doc} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /invoices/{doc} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /shipments/{doc} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // العملاء: أي حد يضيف نفسه، المسجلين فقط يشوفوا
    match /customers/{doc} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // البائعين: للمسجلين فقط
    match /sellers/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
